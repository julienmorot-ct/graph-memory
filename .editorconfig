# =============================================================================
# MCP Memory Service — EditorConfig
# =============================================================================
# https://editorconfig.org

root = true

# ---------------------------------------------------------------------------
# Defaults for all files
# ---------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
[*.py]
indent_size = 4
max_line_length = 120

# ---------------------------------------------------------------------------
# YAML / Docker Compose (2-space indent is the standard convention)
# ---------------------------------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# ---------------------------------------------------------------------------
# JSON
# ---------------------------------------------------------------------------
[*.json]
indent_size = 2

# ---------------------------------------------------------------------------
# TOML (pyproject.toml, etc.)
# ---------------------------------------------------------------------------
[*.toml]
indent_size = 4

# ---------------------------------------------------------------------------
# Markdown
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false

# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------
[*.sh]
indent_size = 2

# ---------------------------------------------------------------------------
# Dockerfile
# ---------------------------------------------------------------------------
[Dockerfile*]
indent_size = 4

# ---------------------------------------------------------------------------
# Caddyfile (WAF config)
# ---------------------------------------------------------------------------
[Caddyfile]
indent_style = tab

# ---------------------------------------------------------------------------
# Env files
# ---------------------------------------------------------------------------
[.env*]
insert_final_newline = true

# ---------------------------------------------------------------------------
# Makefile (tabs required)
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab
